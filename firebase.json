{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "배포_가이드.md",
      "배포하기.bat",
      "database.rules.json",
      "storage.rules",
      "description_game.html"
    ],
    "headers": [
      {
        "source": "**/*.@(js|html|css)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      }
    ],
    "cleanUrls": true
  },
  "database": {
    "rules": "database.rules.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
